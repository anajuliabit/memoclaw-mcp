{
  "name": "memoclaw-mcp",
  "version": "1.17.1",
  "description": "MCP server for MemoClaw semantic memory API. 100 free calls per wallet.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "memoclaw-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@x402/core": "^2.3.0",
    "@x402/evm": "^2.3.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai-agent",
    "semantic-search"
  ],
  "license": "MIT",
  "author": "MemoClaw",
  "repository": {
    "type": "git",
    "url": "https://github.com/anajuliabit/memoclaw-mcp"
  },
  "mcpName": "io.github.anajuliabit/memoclaw-mcp",
  "overrides": {
    "hono": "^4.12.7"
  }
}
